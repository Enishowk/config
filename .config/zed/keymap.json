// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "Editor && (edit_prediction && (showing_completions || in_leading_whitespace))",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-ctrl-shift-alt-tab": "editor::AcceptEditPrediction",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-e": "editor::Hover",
      "cmd-d": "editor::DuplicateLineDown",
      "cmd-space": "editor::ShowCompletions",
      "f9": "editor::SortLinesCaseSensitive",
    },
  },
  {
    "bindings": {
      "cmd-shift-g": "git_panel::ToggleFocus",
      "cmd-\"": "terminal_panel::ToggleFocus",
    },
  },
]
